# crm_tsm local environment
# Generate a new value before first run:
# Linux/macOS: openssl rand -hex 64
# Windows PowerShell: see README.md
SECRET_KEY_BASE=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_64

OPENPROJECT_TAG=17
OPENPROJECT_PORT=8080
OPENPROJECT_HOST_NAME=localhost:8080
OPENPROJECT_HTTPS=false
OPENPROJECT_DEFAULT_LANGUAGE=ru

# Telegram bot MVP, used only when bot profile is started
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_ALLOWED_CHAT_ID=CHANGE_ME
OPENPROJECT_BASE_URL=http://openproject
OPENPROJECT_API_TOKEN=CHANGE_ME
