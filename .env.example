# crm_tsm Leantime environment

LEANTIME_PORT=8082
LEAN_APP_URL=https://crm.equippulse.com

LEAN_DB_DATABASE=leantime
LEAN_DB_USER=leantime
LEAN_DB_PASSWORD=CHANGE_ME_DB_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# Gmail SMTP for Leantime
LEAN_EMAIL_RETURN=no-reply@example.local
LEAN_EMAIL_USE_SMTP=true
LEAN_EMAIL_SMTP_HOSTS=smtp.gmail.com
LEAN_EMAIL_SMTP_AUTH=true
LEAN_EMAIL_SMTP_USERNAME=no-reply@example.local
LEAN_EMAIL_SMTP_PASSWORD=CHANGE_ME_APP_PASSWORD
LEAN_EMAIL_SMTP_AUTO_TLS=true
LEAN_EMAIL_SMTP_SECURE=TLS
LEAN_EMAIL_SMTP_SSLNOVERIFY=false
LEAN_EMAIL_SMTP_PORT=587

# Telegram bot integration
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_ALLOWED_CHAT_ID=CHANGE_ME
TELEGRAM_NOTIFY_CHAT_ID=CHANGE_ME

# Optional: comma-separated Telegram user IDs allowed to use commands.
# Empty value means every user in TELEGRAM_NOTIFY_CHAT_ID / TELEGRAM_ALLOWED_CHAT_ID can use commands.
TELEGRAM_ALLOWED_USER_IDS=

# Read-only DB user for reports, optional fallback to LEAN_DB_USER/LEAN_DB_PASSWORD.
TELEGRAM_DB_USER=telegram_ro
TELEGRAM_DB_PASSWORD=CHANGE_ME_TELEGRAM_RO_PASSWORD

# Write DB user for task creation, optional fallback to LEAN_DB_USER/LEAN_DB_PASSWORD.
TELEGRAM_WRITE_DB_USER=telegram_bot
TELEGRAM_WRITE_DB_PASSWORD=CHANGE_ME_TELEGRAM_WRITE_PASSWORD

# Default task target for /addtask.
TELEGRAM_DEFAULT_PROJECT=Monitoring
TELEGRAM_DEFAULT_ASSIGNEE="Diana Ruban"

# Telegram report limits.
TELEGRAM_REPORT_LIMIT=10
TELEGRAM_REPORT_FILE_LIMIT=500

# Telegram bot runtime.
LEAN_DB_CONTAINER=crm_tsm_leantime_db
CRM_TIMEZONE=Europe/Istanbul
TELEGRAM_TASK_BOT_STATE=/opt/crm_tsm/telegram_task_bot_state.json
